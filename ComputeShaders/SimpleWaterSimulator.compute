#pragma kernel CSMain
#pragma kernel Initialize

#include "Utility.hlsl"
#include "GroundHeight.hlsl"

StructuredBuffer<float4> Source;
RWStructuredBuffer<float4> Target;
RWStructuredBuffer<float> Manipulation;

float3 Size;
float2 StepSize;
float2 StepSizeInv;
uint2 Resolution;

float DeltaTime;

float Gravity;

#define dryThreshold 0.0001

DEFINE_TO_INDEX(Resolution)

float2 CalculateGroundSlope(uint2 coord) {
    uint2 coordPlusOne = min(coord + 1, Resolution - 1);
    uint2 coordMinusOne = max(int2(coord) - 1, int2(0, 0));

    return StepSizeInv * float2(
        GetGroundHeight(coordPlusOne.x, coord.y, Size) - GetGroundHeight(coordMinusOne.x, coord.y, Size),
        GetGroundHeight(coord.x, coordPlusOne.y, Size) - GetGroundHeight(coord.x, coordMinusOne.y, Size)
    ) / (coordPlusOne - coordMinusOne);
}

